{
  "name": "grim-wrapper",
  "displayName": "Grim Wrapper",
  "version": "1.2.2",
  "private": true,
  "description": "Minimalist comment, Markdown, and plain text wrapping",
  "categories": [
    "Formatters"
  ],
  "keywords": [
    "comment",
    "paragraph",
    "wrap",
    "wrapping"
  ],
  "bugs": "https://github.com/sapegin/raccoon-vscode/issues",
  "license": "MIT",
  "author": {
    "name": "Artem Sapegin"
  },
  "repository": {
    "url": "https://github.com/sapegin/raccoon-vscode/tree/main/extensions/grim-wrapper"
  },
  "sponsor": {
    "url": "https://www.buymeacoffee.com/sapegin"
  },
  "publisher": "sapegin",
  "main": "out/extension.js",
  "scripts": {
    "dev": "node ../../esbuild.config.mjs",
    "build": "node ../../esbuild.config.mjs production",
    "publish": "vsce publish",
    "publish:ovsx": "npx ovsx publish"
  },
  "contributes": {
    "commands": [
      {
        "command": "grimWrapper.wrapText",
        "title": "Grim Wrapper: rewrap comment or text",
        "enablement": "!editorReadonly"
      }
    ],
    "configuration": {
      "title": "Grim Wrapper",
      "properties": {
        "grimWrapper.maxLength": {
          "scope": "language-overridable",
          "type": "number",
          "default": 80,
          "description": "Controls maximum length of lines in characters."
        }
      }
    }
  },
  "activationEvents": [
    "onLanguage"
  ],
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#27365a",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  }
}
