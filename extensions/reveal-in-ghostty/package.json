{
  "name": "reveal-in-ghostty",
  "displayName": "Reveal in Ghostty",
  "version": "1.1.0",
  "description": "Reveal current project or folder in Ghostty",
  "categories": [
    "Other"
  ],
  "keywords": [
    "app",
    "application",
    "emulator",
    "external",
    "ghostty",
    "open",
    "reveal",
    "terminal"
  ],
  "bugs": "https://github.com/sapegin/raccoon-vscode/issues",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/sapegin/raccoon-vscode/tree/main/extensions/reveal-in-ghostty"
  },
  "sponsor": {
    "url": "https://www.buymeacoffee.com/sapegin"
  },
  "publisher": "sapegin",
  "main": "out/extension.js",
  "scripts": {
    "dev": "node ../../esbuild.config.mjs",
    "build": "node ../../esbuild.config.mjs production",
    "publish": "vsce publish",
    "publish:ovsx": "npx ovsx publish"
  },
  "contributes": {
    "commands": [
      {
        "command": "revealInGhostty.revealProject",
        "title": "Reveal in Ghostty",
        "category": "Project"
      },
      {
        "command": "revealInGhostty.revealFile",
        "title": "Reveal in Ghostty",
        "category": "File"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "revealInGhostty.revealFile",
          "group": "navigation@21"
        }
      ]
    }
  },
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#ddecff"
  },
  "engines": {
    "vscode": "^1.75.0"
  }
}
