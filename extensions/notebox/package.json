{
  "name": "notebox",
  "displayName": "Notebox",
  "version": "1.0.4",
  "description": "Take quick notes in the panel",
  "categories": [
    "Other"
  ],
  "keywords": [
    "notebook",
    "notebox",
    "notepad",
    "notes",
    "panel",
    "scratchpad",
    "writing"
  ],
  "bugs": "https://github.com/sapegin/raccoon-vscode/issues",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/sapegin/raccoon-vscode/tree/main/extensions/notebox"
  },
  "sponsor": {
    "url": "https://www.buymeacoffee.com/sapegin"
  },
  "publisher": "sapegin",
  "main": "out/extension.js",
  "scripts": {
    "dev": "node ../../esbuild.config.mjs",
    "build": "node ../../esbuild.config.mjs production",
    "publish": "vsce publish",
    "publish:ovsx": "npx ovsx publish"
  },
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "notebox",
          "title": "Notes",
          "icon": "$(note)"
        }
      ]
    },
    "views": {
      "notebox": [
        {
          "type": "webview",
          "id": "notebox.noteboxView",
          "name": "notebox",
          "icon": "$(note)"
        }
      ]
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#daf9f9"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited"
    }
  }
}
