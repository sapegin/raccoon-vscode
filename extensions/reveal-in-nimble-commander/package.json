{
  "name": "reveal-in-nimble-commander",
  "displayName": "Reveal in Nimble Commander",
  "version": "1.0.1",
  "description": "Reveal current project or file in Nimble Commander",
  "categories": [
    "Other"
  ],
  "keywords": [
    "app",
    "application",
    "external",
    "file manager",
    "nimble commander",
    "open",
    "reveal"
  ],
  "bugs": "https://github.com/sapegin/raccoon-vscode/issues",
  "license": "MIT",
  "repository": "https://github.com/sapegin/raccoon-vscode/tree/main/extensions/reveal-in-nimble-commander",
  "sponsor": {
    "url": "https://www.buymeacoffee.com/sapegin"
  },
  "publisher": "sapegin",
  "main": "out/extension.js",
  "scripts": {
    "dev": "node ../../esbuild.config.mjs",
    "build": "node ../../esbuild.config.mjs production",
    "publish": "vsce publish",
    "publish:ovsx": "npx ovsx publish"
  },
  "contributes": {
    "commands": [
      {
        "command": "revealInNimbleCommander.revealProject",
        "title": "Project: Reveal in Nimble Commander"
