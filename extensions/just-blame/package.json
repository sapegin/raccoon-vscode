{
  "name": "just-blame",
  "displayName": "Just Blame: Git Blame annotations",
  "version": "2.0.7",
  "description": "Git Blame annotations sidebar, inspired by JetBrains editors",
  "categories": [
    "Other"
  ],
  "keywords": [
    "annotations",
    "author",
    "blame",
    "changes",
    "git",
    "git blame",
    "history",
    "log",
    "sidebar",
    "source control"
  ],
  "bugs": "https://github.com/sapegin/raccoon-vscode/issues",
  "license": "MIT",
  "author": {
    "name": "Artem Sapegin"
  },
  "repository": {
    "url": "https://github.com/sapegin/raccoon-vscode/tree/main/extensions/just-blame"
  },
  "sponsor": {
    "url": "https://www.buymeacoffee.com/sapegin"
  },
  "publisher": "sapegin",
  "main": "out/extension.js",
  "scripts": {
    "dev": "node ../../esbuild.config.mjs",
    "build": "node ../../esbuild.config.mjs production",
    "publish": "vsce publish",
    "publish:ovsx": "npx ovsx publish"
  },
  "contributes": {
    "commands": [
      {
        "command": "justBlame.toggleBlame",
        "title": "Just Blame: Toggle Git blame annotations",
        "enablement": "editorIsOpen && workbench.scm.active"
      }
    ],
    "configuration": {
      "title": "Just Blame",
      "properties": {
        "justBlame.colorScale": {
          "description": "Colors to show age of blame entries",
          "type": "object",
          "properties": {
            "light": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^#[a-fA-F0-9]{6,8}$"
              }
            },
            "dark": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^#[a-fA-F0-9]{6,8}$"
              }
            }
          },
          "default": {
            "light": [
              "#a4bed0",
              "#aec5d5",
              "#b8ccdb",
              "#c2d4e0",
              "#cddbe5",
              "#d7e2ea",
              "#e1e9ef",
              "#ebf1f5",
              "#f5f8fa",
              "#fcfdfd"
            ],
            "dark": [
              "#65469b",
              "#5e4190",
              "#573c86",
              "#50377b",
              "#493371",
              "#422e66",
              "#3d2b5f",
              "#362654",
              "#2f214a",
              "#291c3f"
            ]
          }
        },
        "justBlame.locale": {
          "description": "Locale to format dates",
          "type": "string",
          "default": "en-GB"
        }
      }
    }
  },
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#ece3fc",
    "theme": "light"
  },
  "engines": {
    "vscode": "^1.75.0"
  }
}
